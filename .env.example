OPENAI_API_KEY=your_openrouter_or_openai_api_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Use -flash for faster searches; -27b works too (OpenRouter reasoning is disabled in-app for Qwen3)
OPENAI_DEFAULT_CHAT_MODEL=qwen/qwen3.6-flash
OPENAI_DEFAULT_CHAT_MODEL_NAME=Qwen3.6 Flash
OPENAI_MODEL_PREFIX=qwen

# Host ports published by docker compose (server deployment)
HOST_PORT=3000
SEARXNG_PORT=8080

# Where the Vane app reaches SearXNG:
# - Docker on the same host (production): leave as http://localhost:8080 (set in docker-compose)
# - Local npm dev using a REMOTE hosted SearXNG: http://YOUR_PUBLIC_IP:8080
# - Local npm dev with local SearXNG container: http://localhost:8080
SEARXNG_API_URL=http://localhost:8080

# Per-request timeout for SearXNG web search (ms). Retries twice on timeout. Default: 30000
# SEARXNG_TIMEOUT_MS=30000

# Asset scraping limits for scrape_url (optional — defaults: 6 URLs/call, 24 verified links/page)
# Increase for multi-source download queries; higher = slower responses
MAX_SCRAPE_URLS_PER_CALL=6
MAX_VERIFY_URLS_PER_PAGE=24
